{
  "name": "fromagerie-app-backend",
  "version": "1.0.0",
  "description": "Backend Node.js/Express - gestion des commandes fromagerie (Gmail + referentiel + CRUD)",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
